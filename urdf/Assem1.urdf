<robot name="Assem1">

  <link name="dummy_link"/>
  <joint name="dummy_joint" type="fixed">
    <origin xyz="0 0 -0.8033" rpy="0 0 0"/> 
    <parent link="dummy_link"/>
    <child link="base_link"/>
  </joint>
  
  <link name="base_link">
    <inertial>
      <origin xyz="0.5487 -1.3806 0.05" rpy="0 0 0"/>
      <mass value="3.000"/>
      <inertia ixx="0.5" ixy="0" ixz="0" iyy="0.08" iyz="0" izz="0.05"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/base_link.STL"/>
      </geometry>
      <material name="white"><color rgba="1 1 1 1"/></material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/base_link.STL"/>
      </geometry>
    </collision>
  </link>

  <link name="banhtrai">
    <inertial>
      <origin xyz="-0.00002 -0.0018 -0.0433" rpy="0 0 0"/>
      <mass value="0.435"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/banhtrai.STL"/>
      </geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.049" length="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="banhtrai_joint" type="continuous">
    <origin xyz="0.3502 -1.3803 0.8523" rpy="-1.5707 0 1.5707"/>
    <parent link="base_link"/>
    <child link="banhtrai"/>
    <axis xyz="0 0 -1"/>
  </joint>

  <gazebo reference="banhtrai">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="banhphai">
    <inertial>
      <origin xyz="0.00002 0.0018 -0.0433" rpy="0 0 0"/>
      <mass value="0.435"/>
      <inertia ixx="0.0003" ixy="0" ixz="0" iyy="0.0003" iyz="0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/banhphai.STL"/>
      </geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.049" length="0.025"/>
      </geometry>
    </collision>
  </link>

  <joint name="banhphai_joint" type="continuous">
    <origin xyz="0.7457 -1.3803 0.8523" rpy="1.5707 0 1.5707"/>
    <parent link="base_link"/>
    <child link="banhphai"/>
    <axis xyz="0 0 1"/>
  </joint>

  <gazebo reference="banhphai">
    <mu1>0.8</mu1>
    <mu2>0.8</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <origin xyz="0.5515 -1.4593 0.8233" rpy="0 0 0"/> 
    <parent link="base_link"/>
    <child link="caster_wheel"/>
  </joint>

  <gazebo reference="caster_wheel">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="caster_wheel_front">
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="black"><color rgba="0 0 0 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.02"/></geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>

  <joint name="caster_joint_front" type="fixed">
    <origin xyz="0.5303 -1.305 0.8233" rpy="0 0 0"/> 
    <parent link="base_link"/>
    <child link="caster_wheel_front"/>
  </joint>

  <gazebo reference="caster_wheel_front">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
    <material>Gazebo/Black</material>
  </gazebo>

  <link name="lidar">
    <inertial>
      <origin xyz="0.0234 -0.0086 0.0114" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/lidar.STL"/>
      </geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/lidar.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.5253 -1.4886 0.9433" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="lidar"/>
  </joint>

  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.02 0.02"/>
      </geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <joint name="imu_joint" type="fixed">
    <origin xyz="0.548 -1.38 0.95" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="imu_link"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
      <material name="blue"><color rgba="0 0 1 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.02 0.05 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.5476 -1.2781 0.9141" rpy="0 0 1.5708"/>
    <parent link="base_link"/>
    <child link="camera_link"/>
  </joint>

  <link name="camera_link_optical"></link>
  
  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="camera_link"/>
    <child link="camera_link_optical"/>
  </joint>

  <link name="khau1">
    <inertial>
      <origin xyz="0.0384 0.0553 0.0069" rpy="0 0 0"/>
      <mass value="0.223"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/khau1.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/khau1.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="khau1_joint" type="revolute">
    <origin xyz="0.5332 -1.3803 0.9933" rpy="1.5708 0 1.5708"/>
    <parent link="base_link"/>
    <child link="khau1"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="100"/>
    <dynamics damping="0.7" friction="1.0"/>
  </joint>

  <link name="khau2">
    <inertial>
      <origin xyz="0.0674 -0.0149 -0.005" rpy="0 0 0"/>
      <mass value="0.143"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/khau2.STL"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://Assem1/meshes/khau2.STL"/>
      </geometry>
    </collision>
  </link>

  <joint name="khau2_joint" type="revolute">
    <origin xyz="0.0856 0.1231 0.0199" rpy="0 0 0"/>
    <parent link="khau1"/>
    <child link="khau2"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="100"/>
    <dynamics damping="0.7" friction="1.0"/>
  </joint>

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <joint name="khau1_joint">
      <command_interface name="position">
        <param name="min">-1.57</param>
        <param name="max">1.57</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="khau2_joint">
      <command_interface name="position">
        <param name="min">-3.14</param>
        <param name="max">3.14</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>/home/nghia/ros2_ws/src/Assem1/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>
  
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
    <self_collide>true</self_collide>
  </gazebo>
  
  <gazebo reference="banhtrai">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="banhphai">
    <material>Gazebo/Black</material>
  </gazebo>
  
  <gazebo reference="lidar">
    <material>Gazebo/Red</material>
  </gazebo>

  <gazebo reference="khau1">
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo reference="khau2">
    <self_collide>true</self_collide>
  </gazebo>

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <left_joint>banhphai_joint</left_joint>
      <right_joint>banhtrai_joint</right_joint>
      <wheel_separation>0.3955</wheel_separation> 
      <wheel_diameter>0.10</wheel_diameter> 
      <max_wheel_torque>5.0</max_wheel_torque>
      <max_wheel_acceleration>0.5</max_wheel_acceleration>

      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>dummy_link</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo reference="imu_link">
    <gravity>true</gravity>
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <visualize>true</visualize>

      <plugin filename="libgazebo_ros_imu_sensor.so" name="imu_plugin">
        <ros>
          <remapping>~/out:=imu/data</remapping>
        </ros>
        <frame_name>imu_link</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
      <pose>0 0 0 0 0 0</pose>
    </sensor>
  </gazebo>

  <gazebo reference="lidar">
    <sensor name="lidar_sensor" type="ray">
      <always_on>true</always_on>
      <visualize>true</visualize> 
      <update_rate>10</update_rate>
      
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min> 
          <max>8.0</max>
          <resolution>0.015</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev> 
        </noise>
      </ray>

      <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
        <ros>
          <remapping>~/out:=scan</remapping>
        </ros>
        <output_type>sensor_msgs/LaserScan</output_type>
        <frame_name>lidar</frame_name>
      </plugin>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <material>Gazebo/Blue</material>
    <sensor type="camera" name="front_camera">
      <always_on>true</always_on>
      <update_rate>30.0</update_rate>
      <visualize>true</visualize>
      
      <camera name="head">
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>300</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.007</stddev>
        </noise>
      </camera>
      
      <plugin name="camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=image_raw</remapping>
          <remapping>~/camera_info:=camera_info</remapping>
        </ros>
        <camera_name>front_camera</camera_name>
        <frame_name>camera_link_optical</frame_name>
        <hack_baseline>0.07</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>
  
  <gazebo>
    <plugin name="gazebo_ros_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
      <update_rate>30</update_rate>
      <joint_name>khau1_joint</joint_name>
      <joint_name>khau2_joint</joint_name>
    </plugin>
  </gazebo>
</robot>